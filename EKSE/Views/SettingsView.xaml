<UserControl x:Class="EKSE.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:everything="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="系统设置"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" Style="{StaticResource EverythingScrollViewerStyle}">
            <StackPanel>
                <!-- 开机自启 -->
                <everything:EverythingCard Margin="0,0,0,15" 
                                           CardVariant="Elevated"
                                           CornerRadius="12"
                                           Padding="20">
                    <everything:EverythingCard.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="开机自启"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="系统启动时自动运行 EKSE"
                                           FontSize="12"
                                           Foreground="Gray"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <everything:EverythingToggleSwitch Grid.Column="1"
                                          x:Name="AutoStartToggle"
                                          SwitchWidth="50"
                                          SwitchHeight="26"
                                          ThumbSize="22"
                                          VerticalAlignment="Center"/>
                        </Grid>
                    </everything:EverythingCard.Header>
                </everything:EverythingCard>

                <!-- 最小化到托盘 -->
                <everything:EverythingCard Margin="0,0,0,15" 
                                           CardVariant="Elevated"
                                           CornerRadius="12"
                                           Padding="20">
                    <everything:EverythingCard.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="最小化到托盘"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="关闭窗口时最小化到系统托盘"
                                           FontSize="12"
                                           Foreground="Gray"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <everything:EverythingToggleSwitch Grid.Column="1"
                                          x:Name="MinimizeToTrayToggle"
                                          SwitchWidth="50"
                                          SwitchHeight="26"
                                          ThumbSize="22"
                                          VerticalAlignment="Center"/>
                        </Grid>
                    </everything:EverythingCard.Header>
                </everything:EverythingCard>

                <!-- 主题设置 -->
                <everything:EverythingCard Margin="0,0,0,15" 
                                           CardVariant="Elevated"
                                           CornerRadius="12"
                                           Padding="20">
                    <everything:EverythingCard.Header>
                        <TextBlock Text="主题设置"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
                    </everything:EverythingCard.Header>
                    <StackPanel>
                        <everything:EverythingComboBox Margin="0,10"
                                  Placeholder="选择主题..."
                                  SelectedIndex="0">
                            <ComboBoxItem>浅色主题</ComboBoxItem>
                            <ComboBoxItem>深色主题</ComboBoxItem>
                        </everything:EverythingComboBox>
                        
                        <TextBlock Text="主题颜色"
                                   FontSize="14"
                                   Margin="0,15,0,10"/>
                        
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" 
                                      VerticalScrollBarVisibility="Disabled">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="PurpleColorOption"
                                             GroupName="Colors" 
                                             Margin="0,0,10,0"
                                             IsChecked="True"
                                             Checked="ColorOption_Checked">
                                    <Ellipse Width="24" Height="24" Fill="Purple"/>
                                </RadioButton>
                                
                                <RadioButton x:Name="BlueColorOption"
                                             GroupName="Colors" 
                                             Margin="0,0,10,0"
                                             Checked="ColorOption_Checked">
                                    <Ellipse Width="24" Height="24" Fill="Blue"/>
                                </RadioButton>
                                
                                <RadioButton x:Name="GreenColorOption"
                                             GroupName="Colors" 
                                             Margin="0,0,10,0"
                                             Checked="ColorOption_Checked">
                                    <Ellipse Width="24" Height="24" Fill="Green"/>
                                </RadioButton>
                                
                                <RadioButton x:Name="OrangeColorOption"
                                             GroupName="Colors" 
                                             Margin="0,0,10,0"
                                             Checked="ColorOption_Checked">
                                    <Ellipse Width="24" Height="24" Fill="Orange"/>
                                </RadioButton>
                                
                                <RadioButton x:Name="RedColorOption"
                                             GroupName="Colors" 
                                             Margin="0,0,10,0"
                                             Checked="ColorOption_Checked">
                                    <Ellipse Width="24" Height="24" Fill="Red"/>
                                </RadioButton>
                                
                                <RadioButton x:Name="PinkColorOption"
                                             GroupName="Colors" 
                                             Margin="0,0,10,0"
                                             Checked="ColorOption_Checked">
                                    <Ellipse Width="24" Height="24" Fill="DeepPink"/>
                                </RadioButton>
                                
                                <RadioButton x:Name="IndigoColorOption"
                                             GroupName="Colors" 
                                             Margin="0,0,10,0"
                                             Checked="ColorOption_Checked">
                                    <Ellipse Width="24" Height="24" Fill="Indigo"/>
                                </RadioButton>
                                
                                <RadioButton x:Name="TealColorOption"
                                             GroupName="Colors" 
                                             Margin="0,0,10,0"
                                             Checked="ColorOption_Checked">
                                    <Ellipse Width="24" Height="24" Fill="Teal"/>
                                </RadioButton>
                                
                                <RadioButton x:Name="LimeColorOption"
                                             GroupName="Colors" 
                                             Checked="ColorOption_Checked">
                                    <Ellipse Width="24" Height="24" Fill="LimeGreen"/>
                                </RadioButton>
                            </StackPanel>
                        </ScrollViewer>
                        
                        <TextBlock Text="音量设置"
                                   FontSize="14"
                                   Margin="0,20,0,10"/>
                        
                        <everything:EverythingSlider Margin="0,0,0,10"
                                  Minimum="0"
                                  Maximum="100"
                                  Value="80"
                                  ThumbColor="#00ACF0"
                                  TrackFillColor="#00ACF0"/>
                    </StackPanel>
                </everything:EverythingCard>

                <!-- 配置管理 -->
                <everything:EverythingCard Margin="0,0,0,15" 
                                           CardVariant="Elevated"
                                           CornerRadius="12"
                                           Padding="20">
                    <everything:EverythingCard.Header>
                        <TextBlock Text="配置管理"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
                    </everything:EverythingCard.Header>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <everything:EverythingButton x:Name="ExportConfigButton"
                                Margin="0,0,10,0"
                                GradientStartColor="#00ACF0"
                                GradientEndColor="#0078D4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📤" Margin="0,0,5,0"/>
                                <TextBlock Text="导出配置"/>
                            </StackPanel>
                        </everything:EverythingButton>
                        
                        <everything:EverythingButton x:Name="ImportConfigButton"
                                Margin="0,0,10,0"
                                GradientStartColor="#00ACF0"
                                GradientEndColor="#0078D4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📥" Margin="0,0,5,0"/>
                                <TextBlock Text="导入配置"/>
                            </StackPanel>
                        </everything:EverythingButton>
                        
                        <everything:EverythingButton x:Name="ResetSettingsButton"
                                GradientStartColor="#808080"
                                GradientEndColor="#383838">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔄" Margin="0,0,5,0"/>
                                <TextBlock Text="重置设置"/>
                            </StackPanel>
                        </everything:EverythingButton>
                    </StackPanel>
                </everything:EverythingCard>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
