<UserControl x:Class="EKSE.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:everything="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="欢迎使用 万物键盘音效"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
            <Image x:Name="HomeImage"
                   Width="120" 
                   Height="120"
                   HorizontalAlignment="Center"/>

            <TextBlock Text="万物键盘音效"
                       FontSize="20"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,10"/>

            <TextBlock Text="点击侧边栏开始配置您的键盘音效"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Foreground="Gray"/>
            
            <everything:EverythingCard Margin="0,30,0,0" 
                                       Width="320" 
                                       CardVariant="Elevated"
                                       CornerRadius="12"
                                       Padding="20">
                <everything:EverythingCard.Header>
                    <TextBlock Text="音效开关" 
                               FontSize="16" 
                               FontWeight="SemiBold"/>
                </everything:EverythingCard.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="启用或禁用键盘音效"
                               FontSize="12"
                               Foreground="Gray"
                               VerticalAlignment="Center"/>

                    <everything:EverythingToggleSwitch Grid.Column="1"
                                  x:Name="SoundToggle"
                                  SwitchWidth="50"
                                  SwitchHeight="26"
                                  ThumbSize="22"
                                  Checked="SoundToggle_Checked"
                                  Unchecked="SoundToggle_Unchecked"/>
                </Grid>
            </everything:EverythingCard>
        </StackPanel>
    </Grid>
</UserControl>
