<UserControl x:Class="EKSE.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                   Text="关于 万物键盘音效"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- 软件介绍内容 -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="20" HorizontalAlignment="Center">
                <!-- Logo -->
                <Image x:Name="LogoImage"
                       Width="128" 
                       Height="128" 
                       HorizontalAlignment="Center"/>
                
                <!-- 软件名称 -->
                <TextBlock Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                           Text="万物键盘音效"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,5"/>
                
                <!-- 软件描述 -->
                <TextBlock Style="{StaticResource MaterialDesignBody1TextBlock}"
                           TextWrapping="Wrap"
                           Text="万物键盘音效 是一款现代化的键盘音效软件，为您的打字过程增添愉悦的声音体验。"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,0,0,10"/>
                
                <!-- 版本号 -->
                <TextBlock Style="{StaticResource MaterialDesignBody1TextBlock}"
                           Text="版本 1.0.0"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
            </StackPanel>

            <Separator Grid.Row="1"/>
        </Grid>

        <!-- 底部区域（按钮和版权信息） -->
        <Grid Grid.Row="2">
            <StackPanel>
                <!-- 按钮区域 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                    <Button Style="{StaticResource GradientButtonStyle}"
                            Margin="5"
                            Click="GithubButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Github" />
                            <TextBlock Text="Github" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource GradientButtonStyle}"
                            Margin="5"
                            Click="QQGroupButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Qqchat" />
                            <TextBlock Text="QQ群" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource GradientButtonStyle}"
                            Margin="5"
                            Click="FeedbackButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CommentQuestionOutline" />
                            <TextBlock Text="问题反馈" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 版权信息 -->
                <Border Background="{DynamicResource PrimaryHueLightBrush}" 
                        CornerRadius="4" 
                        Padding="15" 
                        Margin="0,5,0,0">
                    <TextBlock Style="{StaticResource MaterialDesignBody1TextBlock}"
                               Text="版权所有 (C) 2021-2025 万物永存技术工作室 保留所有权利"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource PrimaryHueDarkBrush}"
                               FontSize="14"
                               FontWeight="Medium"/>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>