<UserControl x:Class="EKSE.Components.VirtualKeyboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EKSE.Components"
             xmlns:everything="clr-namespace:EverythingUI.WPF.Controls;assembly=EverythingUI.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="800">
    
    <Grid x:Name="MainGrid" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 功能说明 -->
        <TextBlock Grid.Row="0" 
                   Text="点击按键测试音效" 
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"
                   FontSize="14"
                   Foreground="Gray"/>

        <!-- 键盘区域 -->
        <Grid Grid.Row="1" x:Name="KeyboardGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- 第一行：Esc, F1-F12 -->
            <Grid Grid.Row="0" Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <everything:EverythingButton Content="Esc" Grid.Column="0" Tag="Escape" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <Border Grid.Column="1" Background="Transparent"/>
                <everything:EverythingButton Content="F1" Grid.Column="2" Tag="F1" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="F2" Grid.Column="3" Tag="F2" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="F3" Grid.Column="4" Tag="F3" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="F4" Grid.Column="5" Tag="F4" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <Border Grid.Column="6" Background="Transparent"/>
                <everything:EverythingButton Content="F5" Grid.Column="7" Tag="F5" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="F6" Grid.Column="8" Tag="F6" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="F7" Grid.Column="9" Tag="F7" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="F8" Grid.Column="10" Tag="F8" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <Border Grid.Column="11" Background="Transparent"/>
                <everything:EverythingButton Content="F9" Grid.Column="12" Tag="F9" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="F10" Grid.Column="13" Tag="F10" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="F11" Grid.Column="14" Tag="F11" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="F12" Grid.Column="15" Tag="F12" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <Border Grid.Column="16" Background="Transparent"/>
                <everything:EverythingButton Content="PrtScn" Grid.Column="17" Tag="PrintScreen" Click="KeyButton_Click" Margin="2" Padding="8,12" FontSize="10" />
            </Grid>
            
            <!-- 第二行：数字键 -->
            <Grid Grid.Row="1" Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <everything:EverythingButton Content="`" Grid.Column="0" Tag="Oem3" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="1" Grid.Column="1" Tag="D1" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="2" Grid.Column="2" Tag="D2" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="3" Grid.Column="3" Tag="D3" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="4" Grid.Column="4" Tag="D4" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="5" Grid.Column="5" Tag="D5" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="6" Grid.Column="6" Tag="D6" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="7" Grid.Column="7" Tag="D7" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="8" Grid.Column="8" Tag="D8" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="9" Grid.Column="9" Tag="D9" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="0" Grid.Column="10" Tag="D0" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="-" Grid.Column="11" Tag="OemMinus" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="=" Grid.Column="12" Tag="OemPlus" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="←" Grid.Column="13" Grid.ColumnSpan="2" Tag="Back" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="Ins" Grid.Column="15" Tag="Insert" Click="KeyButton_Click" Margin="2" Padding="8,12" FontSize="10" />
                <everything:EverythingButton Content="Home" Grid.Column="16" Tag="Home" Click="KeyButton_Click" Margin="2" Padding="8,12" FontSize="10" />
                <everything:EverythingButton Content="PgUp" Grid.Column="17" Tag="PageUp" Click="KeyButton_Click" Margin="2" Padding="8,12" FontSize="10" />
            </Grid>
            
            <!-- 第三行：QWERTY -->
            <Grid Grid.Row="2" Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <everything:EverythingButton Content="Tab" Grid.Column="0" Grid.ColumnSpan="2" Tag="Tab" Click="KeyButton_Click" Margin="2" Padding="8,12" FontSize="10" />
                <everything:EverythingButton Content="Q" Grid.Column="2" Tag="Q" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="W" Grid.Column="3" Tag="W" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="E" Grid.Column="4" Tag="E" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="R" Grid.Column="5" Tag="R" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="T" Grid.Column="6" Tag="T" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="Y" Grid.Column="7" Tag="Y" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="U" Grid.Column="8" Tag="U" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="I" Grid.Column="9" Tag="I" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="O" Grid.Column="10" Tag="O" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="P" Grid.Column="11" Tag="P" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="[" Grid.Column="12" Tag="OemOpenBrackets" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="]" Grid.Column="13" Tag="OemCloseBrackets" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="\" Grid.Column="14" Tag="Oem5" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="Del" Grid.Column="15" Tag="Delete" Click="KeyButton_Click" Margin="2" Padding="8,12" FontSize="10" />
                <everything:EverythingButton Content="End" Grid.Column="16" Tag="End" Click="KeyButton_Click" Margin="2" Padding="8,12" FontSize="10" />
                <everything:EverythingButton Content="PgDn" Grid.Column="17" Tag="PageDown" Click="KeyButton_Click" Margin="2" Padding="8,12" FontSize="10" />
            </Grid>
            
            <!-- 第四行：ASDF -->
            <Grid Grid.Row="3" Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <everything:EverythingButton Content="Caps" Grid.Column="0" Grid.ColumnSpan="2" Tag="CapsLock" Click="KeyButton_Click" Margin="2" Padding="8,12" FontSize="10" />
                <everything:EverythingButton Content="A" Grid.Column="2" Tag="A" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="S" Grid.Column="3" Tag="S" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="D" Grid.Column="4" Tag="D" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="F" Grid.Column="5" Tag="F" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="G" Grid.Column="6" Tag="G" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="H" Grid.Column="7" Tag="H" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="J" Grid.Column="8" Tag="J" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="K" Grid.Column="9" Tag="K" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="L" Grid.Column="10" Tag="L" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content=";" Grid.Column="11" Tag="OemSemicolon" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="'" Grid.Column="12" Tag="OemQuotes" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="Enter" Grid.Column="13" Grid.ColumnSpan="2" Tag="Enter" Click="KeyButton_Click" Margin="2" Padding="8,12" FontSize="10" />
            </Grid>
            
            <!-- 第五行：ZXCV -->
            <Grid Grid.Row="4" Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <everything:EverythingButton Content="Shift" Grid.Column="0" Grid.ColumnSpan="2" Tag="LeftShift" Click="KeyButton_Click" Margin="2" Padding="8,12" FontSize="10" />
                <everything:EverythingButton Content="Z" Grid.Column="2" Tag="Z" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="X" Grid.Column="3" Tag="X" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="C" Grid.Column="4" Tag="C" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="V" Grid.Column="5" Tag="V" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="B" Grid.Column="6" Tag="B" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="N" Grid.Column="7" Tag="N" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="M" Grid.Column="8" Tag="M" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="," Grid.Column="9" Tag="OemComma" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="." Grid.Column="10" Tag="OemPeriod" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="/" Grid.Column="11" Tag="OemQuestion" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="Shift" Grid.Column="12" Grid.ColumnSpan="3" Tag="RightShift" Click="KeyButton_Click" Margin="2" Padding="8,12" FontSize="10" />
                <everything:EverythingButton Content="↑" Grid.Column="16" Tag="Up" Click="KeyButton_Click" Margin="2" Padding="8,12" />
            </Grid>
            
            <!-- 第六行：空格行 -->
            <Grid Grid.Row="5" Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <everything:EverythingButton Content="Ctrl" Grid.Column="0" Tag="LeftCtrl" Click="KeyButton_Click" Margin="2" Padding="8,12" FontSize="10" />
                <everything:EverythingButton Content="Win" Grid.Column="1" Tag="LWin" Click="KeyButton_Click" Margin="2" Padding="8,12" FontSize="10" />
                <everything:EverythingButton Content="Alt" Grid.Column="2" Tag="LeftAlt" Click="KeyButton_Click" Margin="2" Padding="8,12" FontSize="10" />
                <everything:EverythingButton Content="SPACE" Grid.Column="3" Grid.ColumnSpan="8" Tag="Space" Click="KeyButton_Click" Margin="2" Padding="8,12" FontSize="10" />
                <everything:EverythingButton Content="Alt" Grid.Column="11" Tag="RightAlt" Click="KeyButton_Click" Margin="2" Padding="8,12" FontSize="10" />
                <everything:EverythingButton Content="Win" Grid.Column="12" Tag="RWin" Click="KeyButton_Click" Margin="2" Padding="8,12" FontSize="10" />
                <everything:EverythingButton Content="Menu" Grid.Column="13" Tag="Apps" Click="KeyButton_Click" Margin="2" Padding="8,12" FontSize="10" />
                <everything:EverythingButton Content="Ctrl" Grid.Column="14" Tag="RightCtrl" Click="KeyButton_Click" Margin="2" Padding="8,12" FontSize="10" />
                <everything:EverythingButton Content="←" Grid.Column="15" Tag="Left" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="↓" Grid.Column="16" Tag="Down" Click="KeyButton_Click" Margin="2" Padding="8,12" />
                <everything:EverythingButton Content="→" Grid.Column="17" Tag="Right" Click="KeyButton_Click" Margin="2" Padding="8,12" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
